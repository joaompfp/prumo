# Global store instance (lazy init)
_store = None
_use_cache = True

def _get_store():
    global _store
    if _store is None:
        from store import DataStore
        _store = DataStore(db_path=os.getenv("CAE_DATA_DB"))
    return _store

def _set_store(db_path):
    global _store
    from store import DataStore
    _store = DataStore(db_path=db_path)

def cached(source, method, fn, ref_month=None, **params):
    """Wrap a collector call with cache logic.

    If cache is enabled and a valid cached response exists, returns it.
    Otherwise calls fn(), stores the result, and returns it.
    On API failure: returns cached data if available, logs error.
    """
    if not _use_cache:
        return fn()

    store = _get_store()

    # Build cache params (exclude ref_date objects, use ref_month string)
    cache_params = {k: v for k, v in params.items() if v is not None}
    if ref_month:
        cache_params["ref"] = ref_month

    # Check cache
    hit = store.get_cached(source, method, **cache_params)
    if hit is not None:
        return hit

    # Cache miss — call API
    try:
        result = fn()
    except Exception as e:
        # API failed — try to return stale cache
        store.log_error(source, method, str(e), ref_month=ref_month, **cache_params)
        stale = store.get_cached(source, method, **cache_params)
        if stale is not None:
            stale["_cache_warning"] = f"Stale cache (API failed: {e})"
            return stale
        return {"error": str(e), "indicator": method}

    # Store result (only if no error)
    if "error" not in result or result.get("data"):
        try:
            store.store_response(source, method, result,
                                 ref_month=ref_month, **cache_params)
        except Exception as e:
            import sys
            print(f"CACHE WARN: Failed to store {source}/{method}: {e}", file=sys.stderr)

    return result


