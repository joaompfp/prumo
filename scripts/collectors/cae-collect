            lambda: oecd.get_unemployment(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months),
    }

    results = {}
    with ThreadPoolExecutor(max_workers=11) as executor:
        futures = {executor.submit(fn): key for key, fn in tasks.items()}
