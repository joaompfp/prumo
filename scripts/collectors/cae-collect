def db_connect():
    if not DB_PATH.exists():
        print_err(f"Energy database not found: {DB_PATH}")
    return sqlite3.connect(f"file:{DB_PATH}?mode=ro&immutable=1", uri=True)


def db_list_indicators(source=None, category=None):
    conn = db_connect()
    q = """
        SELECT source, category, indicator, unit, period_type,
               MIN(period) as from_period, MAX(period) as to_period, COUNT(*) as points
        FROM indicators
        WHERE 1=1
    """
    params = []
    if source:
        q += " AND source = ?"
        params.append(source.upper())
    if category:
        q += " AND category = ?"
        params.append(category)
    q += " GROUP BY source, category, indicator, unit, period_type ORDER BY source, category, indicator"
    rows = conn.execute(q, params).fetchall()
    conn.close()
    return rows


def db_query(source=None, category=None, indicator=None, period_from=None, period_to=None, region=None, limit=100):
    conn = db_connect()
    q = "SELECT source, category, indicator, region, period, value, unit FROM indicators WHERE 1=1"
    params = []
    if source:
        q += " AND source = ?"
        params.append(source.upper())
    if category:
        q += " AND category = ?"
        params.append(category)
    if indicator:
        q += " AND indicator LIKE ?"
        params.append(f"%{indicator}%")
    if region:
        q += " AND region = ?"
        params.append(region)
    if period_from:
        q += " AND period >= ?"
        params.append(str(period_from))
    if period_to:
        q += " AND period <= ?"
        params.append(str(period_to))
    q += f" ORDER BY source, category, indicator, period DESC LIMIT {limit}"
    rows = conn.execute(q, params).fetchall()
    conn.close()
    return rows


def db_latest(source=None, category=None, n=1):
    """Get latest N records per indicator"""
    conn = db_connect()
    q = """
        SELECT source, category, indicator, region, period, value, unit
        FROM indicators i1
        WHERE 1=1
    """
    params = []
    if source:
        q += " AND source = ?"
        params.append(source.upper())
    if category:
        q += " AND category = ?"
        params.append(category)
    # Get latest per indicator using window function
    q = f"""
        SELECT source, category, indicator, region, period, value, unit
        FROM (
            SELECT *, ROW_NUMBER() OVER (PARTITION BY source, category, indicator ORDER BY period DESC) as rn
            FROM indicators
            WHERE 1=1
            {"AND source = ?" if source else ""}
            {"AND category = ?" if category else ""}
        ) t
        WHERE rn <= {n}
        ORDER BY source, category, indicator, period DESC
    """
    params = []
    if source:
        params.append(source.upper())
    if category:
        params.append(category)
    rows = conn.execute(q, params).fetchall()
    conn.close()
    return rows


