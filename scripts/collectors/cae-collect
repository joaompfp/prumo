#!/usr/bin/env python3
"""
cae-collect — Unified data collection CLI for CAE economic reports.

Usage:
    cae-collect <source> <method> [--param=value ...] [--ref=YYYY-MM] [--no-cache]
    cae-collect list [source]
    cae-collect db <query|indicator> [--source=DGEG] [--category=renewables] [--period-from=2020] [--period-to=2025] [--format=table|json]
    cae-collect dashboard <type> [--months=13] [--ref=YYYY-MM] [--no-cache]
    cae-collect cache <stats|list|clear> [--source=INE] [--older-than=90] [--all]

Sources: ine, eurostat, fred, worldbank, oecd, eredes, dgeg-api, dgeg, erse

Global options:
    --ref=YYYY-MM    Reference month (default: current month). Anchors all
                     period calculations, e.g. --ref=2026-01 --months=13
                     fetches Jan 2025 to Jan 2026 regardless of run date.
    --no-cache       Force fresh API fetch, ignoring cached data.
    --db=PATH        Custom path to cae-data.db (default: data/cae-data.db).

Examples:
    cae-collect list                           # List all sources
    cae-collect list ine                       # List INE methods
    cae-collect ine get_ipi --cae=manufacturing --months=6
    cae-collect ine get_ipi --cae=manufacturing --months=13 --ref=2026-01
    cae-collect dashboard macro --months=13 --ref=2026-01
    cae-collect dashboard commodities --months=12 --no-cache
    cae-collect cache stats                    # Show cache statistics
    cae-collect cache list --source=INE        # List cached fetches
    cae-collect cache clear --older-than=90    # Clear old entries
    cae-collect cache clear --all              # Clear everything
"""

