def _parse_ref(value):
    """Parse --ref=YYYY-MM into a datetime object (last day of month)."""
    import re
    if not re.match(r'^\d{4}-\d{2}$', value):
        print_err(f"Invalid --ref format: '{value}'. Expected YYYY-MM (e.g., 2026-01)")
    year, month = int(value[:4]), int(value[5:7])
    if month < 1 or month > 12:
        print_err(f"Invalid month in --ref: {value}")
    # Reject future dates (data hasn't been published yet)
    now = datetime.now()
    if year > now.year or (year == now.year and month > now.month):
        print_err(f"--ref={value} is in the future. Data not yet available.")
    # Use last day of month as reference
    if month == 12:
        return datetime(year + 1, 1, 1) - __import__('datetime').timedelta(days=1)
    return datetime(year, month + 1, 1) - __import__('datetime').timedelta(days=1)


# Known data availability boundaries per source.
# Requests before these dates will return partial/no data for those sources.
# Format: earliest YYYY-MM with reliable monthly data.
SOURCE_DATA_STARTS = {
    "INE_BASE2021":  "2005-01",  # IPI, employment, wages (Base 2021 series)
    "INE_LEGACY":    "1997-01",  # HICP, confidence (older series)
    "EUROSTAT":      "1999-01",  # IPI, HICP, unemployment
    "OECD":          "1998-01",  # CLI, unemployment, BTS
    "FRED":          "1990-01",  # Commodities (varies by series)
    "WORLDBANK":     "1960",     # Annual only, most indicators from 1960
}
# Absolute minimum: reject dates before 1995 (no source has useful monthly data)
MIN_REF_DATE = "1995-01"


def _validate_ref_date(ref_date, dashboard_type=None):
    """Warn about data availability for historical reference dates.

    Returns list of warning strings (empty if all OK). Does not block execution.
    """
    if ref_date is None:
        return []

    ref_str = ref_date.strftime("%Y-%m")
    warnings = []

    if ref_str < MIN_REF_DATE:
        print(f"WARNING: --ref={ref_str} is before {MIN_REF_DATE}. "
              f"Most sources have no monthly data this far back.",
              file=sys.stderr)

    if dashboard_type in ("macro", "industrial"):
        if ref_str < SOURCE_DATA_STARTS["INE_BASE2021"]:
            warnings.append(
                f"INE Base 2021 series (IPI, employment, wages) start from "
                f"{SOURCE_DATA_STARTS['INE_BASE2021']}. "
                f"These indicators will return empty for --ref={ref_str}."
            )
        if ref_str < SOURCE_DATA_STARTS["EUROSTAT"]:
            warnings.append(
                f"Eurostat monthly data starts from ~{SOURCE_DATA_STARTS['EUROSTAT']}. "
                f"Some indicators may be missing."
            )

    for w in warnings:
        print(f"WARNING: {w}", file=sys.stderr)

    return warnings


def _extract_global_opts(args):
    """Extract --ref, --no-cache, --db from args. Returns (ref_date, remaining_args)."""
    global _use_cache
    ref_date = None
    remaining = []

    for a in args:
        if a.startswith("--ref="):
            ref_date = _parse_ref(a[6:])
        elif a == "--no-cache":
            _use_cache = False
        elif a.startswith("--db="):
            _set_store(a[5:])
        else:
            remaining.append(a)

    return ref_date, remaining


# ============================================================
# Main CLI
# ============================================================

def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        sys.exit(0)

    # Extract global options first
    ref_date, args = _extract_global_opts(args)

    if not args:
        print(__doc__)
        sys.exit(0)

    cmd = args[0].lower()

    # ---- cache ----
    if cmd == "cache":
        if len(args) < 2:
            print("Usage: cae-collect cache <stats|list|clear> [options]")
            sys.exit(1)

        store = _get_store()
        subcmd = args[1].lower()

        params = {}
        for a in args[2:]:
            if a.startswith("--"):
                if "=" in a:
                    k, v = a[2:].split("=", 1)
                    params[k.replace("-", "_")] = v
                else:
                    params[a[2:].replace("-", "_")] = True

        if subcmd == "stats":
            stats = store.cache_stats()
            print(fmt_json(stats))

        elif subcmd == "list":
            entries = store.cache_list(
                source=params.get("source"),
                limit=int(params.get("limit", 50))
            )
            if entries:
                headers = ("Source", "Method", "Ref", "Fetched", "Points", "Status")
                rows = [(e["source"], e["method"], e["ref_month"] or "-",
                         (e["fetched_at"] or "")[:19], e["points"], e["status"])
                        for e in entries]
                print(fmt_table(rows, headers))
            else:
                print("(no cached entries)")

        elif subcmd == "clear":
            clear_all = params.get("all", False)
            older_than = int(params.get("older_than", 0)) or None

            if not clear_all and not older_than and not params.get("source"):
                print("Specify --all, --older-than=DAYS, or --source=NAME")
                sys.exit(1)

            deleted = store.cache_clear(
                source=params.get("source"),
                older_than_days=older_than,
                clear_all=clear_all
            )
            print(f"Deleted: {deleted['indicators']} data points, "
                  f"{deleted['fetch_log']} fetch log entries")

        elif subcmd == "import":
            # Import from legacy energy-data.db
            legacy_path = params.get("path", str(DB_PATH))
            count = store.import_energy_db(legacy_path)
            print(f"Imported {count} records from {legacy_path}")

        else:
            print_err(f"Unknown cache subcommand: {subcmd}. Valid: stats, list, clear, import")

        sys.exit(0)

    # ---- list ----
    if cmd == "list":
        if len(args) < 2:
            print("Available sources:")
            print("  ine        — INE (Instituto Nacional de Estatística, Portugal)")
            print("  eurostat   — Eurostat (EU statistics)")
            print("  fred       — FRED (Federal Reserve Economic Data, commodities)")
            print("  worldbank  — World Bank (global development indicators)")
            print("  oecd       — OECD (confidence, BTS, unemployment, CPI)")
            print("  eredes     — E-REDES Open Data (consumption, production, CAE by geography)")
            print("  dgeg-api   — DGEG fuel prices API (real-time station prices)")
            print("  dgeg       — DGEG energy data (via SQLite DB)")
            print("  erse       — ERSE electricity tariffs (via SQLite DB)")
            print()
            print("Usage: cae-collect list <source>")
            sys.exit(0)

        source = args[1].lower().replace("-", "_")
        if source in ("dgeg", "erse"):
            rows = db_list_indicators(source=source.upper())
            headers = ("Source", "Category", "Indicator", "Unit", "Freq", "From", "To", "Pts")
            print(fmt_table(rows, headers))
        else:
            # Try file-based listing first (no dependency needed)
            methods = list_methods_from_file(source)
            if methods is None:
                # Fall back to import-based listing
                client = get_client(source)
                methods = list_methods(client)
            if not methods:
                print(f"No public methods found for {source}")
            else:
                print(f"\n{source.upper()} methods ({len(methods)}):\n")
                for name, doc in methods:
                    print(f"  {name}")
                    if doc:
                        print(f"    {doc[:100]}")
        sys.exit(0)

    # ---- db ----
    if cmd == "db":
        if len(args) < 2:
            print("Usage: cae-collect db <list|query|latest> [options]")
            sys.exit(1)

        subcmd = args[1].lower()
        # Parse --key=value params
        params = {}
        for a in args[2:]:
            if a.startswith("--"):
                if "=" in a:
                    k, v = a[2:].split("=", 1)
                    params[k.replace("-", "_")] = v
                else:
                    params[a[2:].replace("-", "_")] = True

        output_format = params.pop("format", "table")

        if subcmd == "list":
            rows = db_list_indicators(
                source=params.get("source"),
                category=params.get("category")
            )
            if output_format == "json":
                data = [{"source": r[0], "category": r[1], "indicator": r[2],
                         "unit": r[3], "freq": r[4], "from": r[5], "to": r[6], "points": r[7]}
                        for r in rows]
                print(fmt_json(data))
            else:
                headers = ("Source", "Category", "Indicator", "Unit", "Freq", "From", "To", "Pts")
                print(fmt_table(rows, headers))

        elif subcmd == "query":
            rows = db_query(
                source=params.get("source"),
                category=params.get("category"),
                indicator=params.get("indicator"),
                period_from=params.get("period_from"),
                period_to=params.get("period_to"),
                region=params.get("region"),
                limit=int(params.get("limit", 100))
            )
            if output_format == "json":
                data = [{"source": r[0], "category": r[1], "indicator": r[2],
                         "region": r[3], "period": r[4], "value": r[5], "unit": r[6]}
                        for r in rows]
                print(fmt_json(data))
            else:
                headers = ("Source", "Category", "Indicator", "Region", "Period", "Value", "Unit")
                print(fmt_table(rows, headers))

        elif subcmd == "latest":
            n = int(params.get("n", 1))
            rows = db_latest(
                source=params.get("source"),
                category=params.get("category"),
                n=n
            )
            if output_format == "json":
                data = [{"source": r[0], "category": r[1], "indicator": r[2],
                         "region": r[3], "period": r[4], "value": r[5], "unit": r[6]}
                        for r in rows]
                print(fmt_json(data))
            else:
                headers = ("Source", "Category", "Indicator", "Region", "Period", "Value", "Unit")
                print(fmt_table(rows, headers))

        else:
            print_err(f"Unknown db subcommand: {subcmd}. Valid: list, query, latest")

        sys.exit(0)

    # ---- dashboard ----
    if cmd == "dashboard":
        if len(args) < 2:
            print("Usage: cae-collect dashboard <macro|industrial|energy|commodities|financial|grid> [--months=13] [--ref=YYYY-MM]")
            sys.exit(1)

        dtype = args[1].lower()
        params = {}
        for a in args[2:]:
            if a.startswith("--") and "=" in a:
                k, v = a[2:].split("=", 1)
                params[k] = coerce_param(v)

        months = params.get("months", 13)

        # Validate historical depth
        _validate_ref_date(ref_date, dashboard_type=dtype)

        if dtype == "macro":
            data = dashboard_macro(months=months, ref_date=ref_date)
        elif dtype == "industrial":
            data = dashboard_industrial(months=months, ref_date=ref_date)
        elif dtype == "energy":
            data = dashboard_energy()
        elif dtype == "commodities":
            data = dashboard_commodities(months=months, ref_date=ref_date)
        elif dtype == "financial":
            data = dashboard_financial(months=months, ref_date=ref_date)
        elif dtype == "grid":
            data = dashboard_grid(months=months, ref_date=ref_date)
        else:
            print_err(f"Unknown dashboard type: {dtype}. Valid: macro, industrial, energy, commodities, financial, grid")

        print(fmt_json(data))
        sys.exit(0)

    # ---- source method ----
    # Parse: cae-collect <source> <method> [--param=value ...]
    if len(args) < 2:
        print_err(f"Usage: cae-collect <source> <method> [--param=value ...]")

    source = cmd.replace("-", "_")
    method_name = args[1]

    # Parse params
    params = {}
    for a in args[2:]:
        if a.startswith("--"):
            if "=" in a:
                k, v = a[2:].split("=", 1)
                params[k] = coerce_param(v)
            else:
                params[a[2:]] = True

    # Special handling for db sources
    if source in ("dgeg", "erse"):
        print_err(f"Use 'cae-collect db' for {source.upper()} data. Example: cae-collect db query --source={source.upper()}")

    client = get_client(source)

    # Handle special dashboard methods
    if method_name == "commodity_dashboard" and source == "fred":
        months = params.get("months", 12)
        data = client.get_commodity_dashboard(months=months, ref_date=ref_date)
        print(fmt_json(data))
        sys.exit(0)

    # Get and call the method
    if not hasattr(client, method_name):
        print_err(f"Method '{method_name}' not found on {source}. Use 'cae-collect list {source}' to see available methods.")

    method = getattr(client, method_name)
    if not callable(method):
        print_err(f"'{method_name}' is not a callable method on {source}")

    # Inject ref_date if the method accepts it
    if ref_date:
        import inspect
        sig = inspect.signature(method)
        if "ref_date" in sig.parameters:
            params["ref_date"] = ref_date

    try:
        result = method(**params)
        print(fmt_json(result))
    except TypeError as e:
        print_err(f"Parameter error calling {source}.{method_name}(): {e}")
    except Exception as e:
        print_err(f"Error calling {source}.{method_name}(): {e}")


if __name__ == "__main__":
    main()
