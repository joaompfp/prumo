def list_methods(client):
    """List public convenience methods of a client"""
    methods = []
    for name in sorted(dir(client)):
        if name.startswith("_") or name.startswith("get_data") or name == "BASE_URL":
            continue
        attr = getattr(client, name)
        if callable(attr) and not isinstance(attr, type):
            doc = (attr.__doc__ or "").strip().split("\n")[0]
            methods.append((name, doc))
    return methods


def list_methods_from_file(source):
    """Parse method names from source file without importing (avoids dependency issues)"""
    source_files = {
        "ine": "collectors/ine.py",
        "eurostat": "collectors/eurostat.py",
        "fred": "collectors/fred.py",
        "worldbank": "collectors/worldbank.py",
        "oecd": "collectors/oecd.py",
        "eredes": "collectors/eredes.py",
        "dgeg_api": "collectors/dgeg_fuel_api.py",
        "bportugal": "collectors/bportugal.py",
        "ren": "collectors/ren.py",
    }
    if source not in source_files:
        return None
    filepath = SKILL_DIR / source_files[source]
    if not filepath.exists():
        return None
    methods = []
    import re
    with open(filepath) as f:
        for line in f:
            m = re.match(r'    def (get_\w+|compare_\w+)\(', line)
            if m:
                name = m.group(1)
                if not name.startswith("_"):
                    methods.append((name, ""))
    # Read docstrings in a second pass
    content = filepath.read_text()
    for i, (name, _) in enumerate(methods):
        pattern = rf'def {name}\([^)]*\).*?:\s*\n\s*"""([^"]*)'
        match = re.search(pattern, content, re.DOTALL)
        if match:
            doc = match.group(1).strip().split("\n")[0]
            methods[i] = (name, doc)
    return methods


def coerce_param(value):
    """Convert string param values to appropriate types"""
    if value.lower() == "true":
        return True
    if value.lower() == "false":
        return False
    try:
        return int(value)
    except ValueError:
        pass
    try:
        return float(value)
    except ValueError:
        pass
    # Handle lists: "PT,ES,DE" → ["PT", "ES", "DE"]
    if "," in value:
        return [v.strip() for v in value.split(",")]
    return value


