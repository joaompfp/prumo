def dashboard_macro(months=13, ref_date=None):
    """Collect macro indicators from multiple sources — parallel via ThreadPoolExecutor"""
    from concurrent.futures import ThreadPoolExecutor, as_completed

    from collectors.ine import INEClient
    from collectors.eurostat import EurostatClient
    from collectors.oecd import OECDClient
    ine = INEClient()
    eu  = EurostatClient()
    oecd = OECDClient()

    ref_month = ref_date.strftime("%Y-%m") if ref_date else None

    tasks = {
        "ine_ipi":              lambda: cached("INE", "get_ipi",
            lambda: ine.get_ipi(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months, cae="manufacturing"),
        "ine_ipi_yoy":          lambda: cached("INE", "get_ipi_yoy",
            lambda: ine.get_ipi_yoy(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months, cae="manufacturing"),
        "ine_employment":       lambda: cached("INE", "get_employment",
            lambda: ine.get_employment(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months),
        "ine_wages":            lambda: cached("INE", "get_wages",
            lambda: ine.get_wages(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months),
        "ine_confidence":       lambda: cached("INE", "get_confidence",
            lambda: ine.get_confidence(sector="manufacturing", months=months, ref_date=ref_date),
            ref_month=ref_month, months=months, sector="manufacturing"),
        "ine_hicp":             lambda: cached("INE", "get_hicp",
            lambda: ine.get_hicp(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months),
        "eurostat_ipi":         lambda: cached("EUROSTAT", "get_ipi_portugal",
            lambda: eu.get_ipi_portugal(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months),
        "eurostat_unemployment":lambda: cached("EUROSTAT", "get_unemployment_portugal",
            lambda: eu.get_unemployment_portugal(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months),
        "eurostat_hicp":        lambda: cached("EUROSTAT", "get_hicp_portugal",
            lambda: eu.get_hicp_portugal(months=months, ref_date=ref_date),
            ref_month=ref_month, months=months),
        "oecd_cli_business":    lambda: cached("OECD", "get_cli",
            lambda: oecd.get_cli(measure="business_confidence", months=months, ref_date=ref_date),
